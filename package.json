{
  "name": "entry-book",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron-start": "electron .",
    "dist": "next build && electron-builder"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@mui/x-data-grid": "^9.7.0",
    "next": "16.2.9",
    "prop-types": "^15.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4"
  },
  "build": {
    "appId": "com.entrybook.app",
    "productName": "EntryBook",
    "win": {
      "target": "nsis"
